<!DOCTYPE html>

<html lang="mn">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="theme-color" content="#05070d" />
<title>Gan-Erdene — Developer · Forex AI Trader · Zweiradmechatroniker</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700;800&family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#05070d;
  --bg2:#08101c;
  --panel:rgba(12,19,34,.72);
  --panel2:rgba(15,23,40,.86);
  --line:rgba(255,255,255,.08);
  --text:#e9f2ff;
  --muted:#8b9bb8;
  --cyan:#00fff0;
  --green:#00ffaa;
  --blue:#00c8ff;
  --pink:#ff4fd8;
  --gold:#ffcf5a;
  --shadow:0 20px 60px rgba(0,0,0,.45);
  --radius:22px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  background:
    radial-gradient(circle at top,rgba(0,255,240,.08),transparent 30%),
    radial-gradient(circle at 80% 20%,rgba(255,79,216,.08),transparent 24%),
    linear-gradient(180deg,var(--bg) 0%,#060b14 45%,#04060b 100%);
  color:var(--text);
  font-family:Inter,sans-serif;
  overflow-x:hidden;
}
a{text-decoration:none;color:inherit}
body:before{
  content:'';
  position:fixed;
  inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.045'/%3E%3C/svg%3E");
  pointer-events:none;
  opacity:.45;
  z-index:0
}
nav,.hero,section,footer,.ticker-wrap{position:relative;z-index:1}
nav{
  position:fixed;
  inset:0 0 auto 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:1rem 3rem;
  background:rgba(5,7,13,.72);
  -webkit-backdrop-filter:blur(22px);
  backdrop-filter:blur(22px);
  border-bottom:1px solid rgba(255,255,255,.06)
}
.logo{
  font-family:Syne,sans-serif;
  font-size:1.15rem;
  font-weight:800;
  letter-spacing:-.03em
}
.logo span{color:var(--cyan)}
.links{
  display:flex;
  gap:1.6rem;
  list-style:none;
  padding:0;
  margin:0
}
.links a{
  font:700 .72rem/1 Space Mono,monospace;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:var(--muted)
}
.links a:hover{color:var(--cyan)}
.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:.5rem;
  padding:.9rem 1.25rem;
  border:1px solid rgba(0,255,240,.28);
  background:linear-gradient(135deg,rgba(0,255,240,.18),rgba(123,47,255,.14));
  color:var(--text);
  font:700 .78rem/1 Syne,sans-serif;
  letter-spacing:.08em;
  text-transform:uppercase;
  transition:.25s;
  box-shadow:0 0 0 1px rgba(0,255,240,.06) inset;
  cursor:pointer
}
.btn:hover{
  transform:translateY(-2px);
  border-color:var(--cyan);
  box-shadow:0 18px 40px rgba(0,255,240,.12)
}
.btn.secondary{background:transparent;border-color:rgba(255,255,255,.11)}
.hero{
  min-height:100svh;
  display:grid;
  align-items:center;
  padding:7.5rem 3rem 4rem;
  overflow:hidden
}
.hero:before{
  content:'';
  position:absolute;
  inset:0;
  background:
    radial-gradient(ellipse at 80% 30%,rgba(0,255,240,.12),transparent 28%),
    radial-gradient(ellipse at 15% 70%,rgba(255,79,216,.09),transparent 24%)
}
.hero-grid{
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);
  background-size:72px 72px;
  mask-image:radial-gradient(circle at center,#000 28%,transparent 70%)
}
.hero-orb{
  position:absolute;
  width:420px;
  height:420px;
  border-radius:50%;
  right:-120px;
  top:80px;
  background:radial-gradient(circle,rgba(0,255,240,.18),rgba(123,47,255,.08) 42%,transparent 68%);
  filter:blur(10px);
  animation:floatOrb 10s ease-in-out infinite
}
@keyframes floatOrb{
  0%,100%{transform:translateY(0) scale(1)}
  50%{transform:translateY(-18px) scale(1.03)}
}
.kicker{
  font:700 .7rem/1 Space Mono,monospace;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--cyan);
  display:inline-flex;
  align-items:center;
  gap:.55rem
}
.dot{
  width:7px;
  height:7px;
  border-radius:50%;
  background:var(--cyan);
  box-shadow:0 0 14px var(--cyan);
  animation:pulse 2s ease-in-out infinite
}
@keyframes pulse{
  0%,100%{box-shadow:0 0 14px var(--cyan)}
  50%{box-shadow:0 0 28px var(--cyan),0 0 50px rgba(0,255,240,.4)}
}
h1{
  font-family:Syne,sans-serif;
  font-size:clamp(3.2rem,8vw,7.6rem);
  line-height:.92;
  letter-spacing:-.05em;
  margin:.9rem 0 0;
  max-width:10ch
}
h1 .c1{color:var(--cyan)}
h1 .c2{color:var(--pink)}
.sub{
  max-width:640px;
  margin:1.5rem 0 0;
  color:var(--muted);
  font-size:1.02rem;
  line-height:1.85
}
.hero-actions{
  display:flex;
  flex-wrap:wrap;
  gap:.9rem;
  margin-top:2rem
}
.stats{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:1rem;
  margin-top:2.6rem;
  max-width:980px
}
.stat{
  padding:1.15rem 1.2rem;
  background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));
  border:1px solid rgba(255,255,255,.08);
  -webkit-backdrop-filter:blur(10px);
  backdrop-filter:blur(10px);
  border-radius:18px
}
.stat .n{font:800 1.45rem Syne,sans-serif}
.stat .l{
  margin-top:.25rem;
  color:var(--muted);
  font-size:.78rem;
  letter-spacing:.04em
}
.scroll{
  position:absolute;
  left:50%;
  bottom:1.7rem;
  transform:translateX(-50%);
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:.45rem;
  color:var(--muted);
  font:700 .62rem Space Mono,monospace;
  letter-spacing:.2em;
  text-transform:uppercase
}
.line{
  width:1px;
  height:56px;
  background:linear-gradient(to bottom,var(--cyan),transparent);
  animation:move 2s ease-in-out infinite
}
@keyframes move{
  0%{transform:scaleY(.2)}
  50%{transform:scaleY(1)}
  100%{transform:scaleY(.2)}
}
section{padding:7rem 3rem}
.wrap{max-width:1200px;margin:0 auto}
.tag{
  font:700 .65rem Space Mono,monospace;
  letter-spacing:.24em;
  text-transform:uppercase;
  color:var(--cyan);
  margin-bottom:1rem
}
.title{
  font-family:Syne,sans-serif;
  font-size:clamp(2rem,4vw,3.6rem);
  line-height:1.05;
  letter-spacing:-.04em;
  margin:0 0 1rem
}
.lead{
  color:var(--muted);
  line-height:1.9;
  max-width:820px
}
.grid2{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:1.4rem;
  align-items:start
}
.panel{
  background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));
  border:1px solid rgba(255,255,255,.08);
  box-shadow:var(--shadow);
  padding:1.4rem;
  position:relative;
  overflow:hidden;
  border-radius:var(--radius)
}
.panel:before{
  content:'';
  position:absolute;
  inset:0 0 auto 0;
  height:2px;
  background:linear-gradient(90deg,var(--cyan),var(--pink),transparent)
}
.badges,.skills,.services,.projects{
  display:grid;
  gap:1rem
}
.badges{
  grid-template-columns:repeat(3,minmax(0,1fr));
  margin-top:1.25rem
}
.badge{
  padding:.6rem .8rem;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.02);
  font:700 .72rem Space Mono,monospace;
  color:var(--muted);
  border-radius:999px
}
.badge.hot{
  color:var(--cyan);
  border-color:rgba(0,255,240,.22);
  background:rgba(0,255,240,.05)
}
.skills{
  grid-template-columns:repeat(3,minmax(0,1fr));
  margin-top:2rem
}
.card{
  background:linear-gradient(180deg,rgba(16,24,40,.9),rgba(8,12,20,.92));
  border:1px solid rgba(255,255,255,.08);
  padding:1.35rem;
  transition:.25s;
  position:relative;
  overflow:hidden;
  border-radius:var(--radius)
}
.card:hover{
  transform:translateY(-4px);
  border-color:rgba(0,255,240,.24);
  box-shadow:0 24px 50px rgba(0,0,0,.35)
}
.card .icon{font-size:1.5rem}
.card h3{
  font:800 1.05rem Syne,sans-serif;
  margin:.85rem 0 .5rem
}
.card p{
  color:var(--muted);
  line-height:1.8;
  font-size:.88rem
}
.chiprow{
  display:flex;
  flex-wrap:wrap;
  gap:.45rem;
  margin-top:1rem
}
.chip{
  font:700 .62rem Space Mono,monospace;
  letter-spacing:.1em;
  padding:.28rem .5rem;
  background:rgba(255,255,255,.04);
  color:#aab7cf;
  border-radius:999px
}
.ticker-wrap{
  padding:1rem 0;
  background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.01));
  border-top:1px solid rgba(255,255,255,.06);
  border-bottom:1px solid rgba(255,255,255,.06);
  overflow:hidden
}
.ticker{
  display:flex;
  gap:2.2rem;
  width:max-content;
  animation:slide 24s linear infinite;
  padding-left:2rem
}
.t{
  display:flex;
  gap:.55rem;
  white-space:nowrap;
  font:700 .72rem Space Mono,monospace
}
.p{color:var(--text)}
.v{color:var(--muted)}
.up{color:#00f5a0}
.down{color:#ff5c7c}
@keyframes slide{
  from{transform:translateX(0)}
  to{transform:translateX(-50%)}
}
.services,.projects{
  grid-template-columns:repeat(2,minmax(0,1fr));
  margin-top:2rem
}
.price{
  margin-top:1rem;
  color:var(--cyan);
  font:700 .68rem Space Mono,monospace;
  letter-spacing:.14em;
  text-transform:uppercase
}
.project-thumb{
  height:160px;
  display:grid;
  place-items:center;
  font-size:2.5rem;
  background:
    radial-gradient(circle at 30% 30%,rgba(0,255,240,.12),transparent 35%),
    linear-gradient(135deg,#09101d,#081726 55%,#100a1b);
  border-radius:18px
}
.contact{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1.4rem;
  margin-top:2rem
}
.link{
  display:flex;
  align-items:center;
  gap:1rem;
  padding:1rem 1.1rem;
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  transition:.2s
}
.link:hover{border-color:rgba(0,255,240,.2);background:rgba(0,255,240,.03)}
.label{
  font:700 .66rem Space Mono,monospace;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--muted);
  display:block
}
.val{margin-top:.2rem}
.form{
  display:grid;
  gap:.9rem
}
.input,.textarea{
  width:100%;
  border:1px solid rgba(255,255,255,.1);
  background:rgba(255,255,255,.03);
  color:var(--text);
  padding:1rem 1.05rem;
  font:500 .95rem Inter,sans-serif;
  outline:none;
  border-radius:16px;
  transition:.2s
}
.input:focus,.textarea:focus{
  border-color:var(--cyan);
  box-shadow:0 0 0 4px rgba(0,255,240,.08)
}
.textarea{
  min-height:140px;
  resize:vertical
}
footer{
  padding:1.5rem 3rem 2.2rem;
  border-top:1px solid rgba(255,255,255,.06);
  display:flex;
  justify-content:space-between;
  gap:1rem;
  color:var(--muted);
  font:700 .62rem Space Mono,monospace;
  letter-spacing:.18em;
  text-transform:uppercase
}
hr.sep{
  border:0;
  height:1px;
  background:linear-gradient(90deg,transparent,rgba(0,255,240,.55),transparent);
  margin:1.75rem 0;
  opacity:.55
}
.reveal{
  opacity:0;
  transform:translateY(24px);
  transition:opacity .7s ease, transform .7s ease
}
.reveal.show{
  opacity:1;
  transform:none
}
.floating-cta{
  position:fixed;
  right:1rem;
  bottom:1rem;
  z-index:20;
  display:none
}
.mobilebar{
  position:fixed;
  left:0;
  right:0;
  bottom:0;
  display:none;
  gap:.5rem;
  padding:.75rem 1rem calc(.75rem + env(safe-area-inset-bottom));
  background:rgba(5,7,13,.82);
  -webkit-backdrop-filter:blur(18px);
  backdrop-filter:blur(18px);
  border-top:1px solid rgba(255,255,255,.06);
  z-index:20
}
.mobilebar a{
  flex:1;
  text-align:center;
  padding:.8rem .7rem;
  border:1px solid rgba(255,255,255,.08);
  border-radius:14px;
  font:700 .7rem Space Mono,monospace;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted)
}
.mobilebar a.primary{
  color:var(--text);
  border-color:rgba(0,255,240,.24);
  background:rgba(0,255,240,.06)
}
/* Toast */
.toast{
  position:fixed;
  bottom:5rem;
  right:1rem;
  padding:.9rem 1.4rem;
  background:rgba(0,255,240,.12);
  border:1px solid rgba(0,255,240,.4);
  color:var(--cyan);
  font:700 .78rem Space Mono,monospace;
  letter-spacing:.1em;
  border-radius:14px;
  z-index:999;
  transform:translateY(100px);
  opacity:0;
  transition:.4s cubic-bezier(.16,1,.3,1)
}
.toast.show{transform:translateY(0);opacity:1}
@media (max-width: 980px){
  nav{padding:1rem 1.2rem}
  .links{display:none}
  .hero,section,footer{padding-left:1.2rem;padding-right:1.2rem}
  .grid2,.contact,.services,.projects{grid-template-columns:1fr}
  .skills,.stats,.badges{grid-template-columns:1fr 1fr}
  .hero{padding-top:6.8rem}
  h1{max-width:12ch}
  .scroll{display:none}
}
@media (max-width: 640px){
  h1{font-size:clamp(2.8rem,15vw,4.2rem)}
  .skills,.stats,.badges{grid-template-columns:1fr}
  .hero-actions .btn{width:100%}
  .card,.panel{padding:1.1rem}
  .sub,.lead{font-size:.98rem;line-height:1.8}
  .floating-cta,.mobilebar{display:flex}
  footer{padding-bottom:5rem}
}
@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto}
  *,*::before,*::after{
    animation-duration:.01ms !important;
    animation-iteration-count:1 !important;
    transition-duration:.01ms !important;
    scroll-behavior:auto !important
  }
}
</style>
</head>
